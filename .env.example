# LLM (Claude Opus 4.6 via LiteLLM proxy)
LITELLM_BASE_URL=https://litellm.com
LITELLM_API_KEY=your_litellm_key
LITELLM_MODEL=claude-opus-4-6

# Bright Data
BRIGHTDATA_API_KEY=your_bright_data_api_key
BRIGHTDATA_SERP_API_URL=https://api.brightdata.com/serp
BRIGHTDATA_WEB_UNLOCKER_URL=https://api.brightdata.com/unlocker
BRIGHTDATA_SCRAPING_BROWSER_WS=wss://brd-customer-XXXX-zone-XXXX@brd.superproxy.io:9222
BRIGHTDATA_MCP_SERVER_URL=

# Infrastructure (auto-configured by Docker Compose — override for local dev)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
DATABASE_URL=postgresql://sentinel:sentinel@postgres:5432/sentinel

# Integrations (optional)
SLACK_WEBHOOK_URL=
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Environment inventory paths (mounted via Docker volume)
KUBECONFIG_PATH=./environment/sample-kubeconfig.yaml
TERRAFORM_STATE_PATH=./environment/sample-terraform.tfstate
VENDOR_INVENTORY_PATH=./environment/sample-vendors.json
